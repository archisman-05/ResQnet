# Demo mode — uses localStorage, no backend needed (default: true)
NEXT_PUBLIC_DEMO_MODE=true

# Set to false and fill these in to use real backend:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=http://localhost:5000

# Google Maps JavaScript API key (Maps JavaScript API enabled)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
